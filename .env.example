# Optional in production. If omitted, the backend uses the live request origin.
PUBLIC_APP_URL=

# Optional for same-origin deployments. Use a full backend URL only when frontend and API are hosted separately.
VITE_API_BASE_URL=/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/campusconnect?retryWrites=true&w=majority
